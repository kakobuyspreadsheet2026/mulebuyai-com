# Copy to .env to override the default MaisonLooks spreadsheet hub URL
# Default if unset: https://maisonlooks.com/en/spreadsheet/mulebuy
PUBLIC_MULEBUY_SPREADSHEET_URL=

# TOP promo strip → `/join/discord` redirect (optional; default in src/consts.ts).
# PUBLIC_MULEBUY_DISCORD_URL=https://discord.com/invite/YOUR_INVITE

# Floating right dock (Video / Discord / Reddit / WhatsApp). Optional overrides — see defaults in src/consts.ts.
# PUBLIC_FLOAT_VIDEO_URL=https://example.com/my-intro.mp4
# PUBLIC_FLOAT_DISCORD_URL=https://discord.com/invite/YOUR_INVITE
# PUBLIC_FLOAT_REDDIT_URL=https://www.reddit.com/r/mulebuyfinds/
# PUBLIC_FLOAT_WHATSAPP_URL=https://wa.me/447594927259
