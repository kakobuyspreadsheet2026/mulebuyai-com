---
import Layout from '../layouts/Layout.astro';
import LocaleHomeStub from '../components/LocaleHomeStub.astro';
import { canonicalHref, siteStructuredDataIds } from '../consts';
import { enHome } from '../i18n/stubs/en';

export const prerender = true;

const locale = 'en';
const canonicalPath = '/';

const origin = Astro.site?.origin ?? 'https://mulebuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = canonicalHref(Astro.site, canonicalPath);

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: enHome.webPageName,
  url: pageUrl,
  description: enHome.description,
  inLanguage: 'en',
  isPartOf: { '@id': websiteId },
  keywords: enHome.webPageKeywords,
};
---

<Layout
  title={enHome.title}
  description={enHome.description}
  canonicalPath={canonicalPath}
  locale={locale}
  i18nRouteSegment=""
  jsonLd={webPageLd}
  showDiscordTopBanner={false}
>
  <LocaleHomeStub content={enHome} />
</Layout>

<style>
  .home-main-centered .wrap {
    text-align: center;
  }
  .home-main-centered h2 {
    margin-left: auto;
    margin-right: auto;
    max-width: 52rem;
  }
  .home-main-centered .section-intro {
    margin-left: auto;
    margin-right: auto;
  }
  .home-main-centered .guide h3 {
    margin-left: auto;
    margin-right: auto;
    max-width: 52rem;
  }
  .home-main-centered .guide p {
    margin-left: auto;
    margin-right: auto;
  }
  .home-main-centered .cta-row {
    justify-content: center;
  }

  .home-main-centered .guide h3 + p + p {
    margin-top: 0.65rem;
  }
</style>
