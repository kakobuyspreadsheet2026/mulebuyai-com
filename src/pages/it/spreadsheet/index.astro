---
import Layout from '../../../layouts/Layout.astro';
import SpreadsheetPageBody from '../../../components/pages/SpreadsheetPageBody.astro';
import { canonicalHref, ml, siteStructuredDataIds } from '../../../consts';
import {
  getSpreadsheetPageCopy,
  hydrateSpreadsheetCopy,
} from '../../../i18n/copy/spreadsheetPage';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { breadcrumbListLd, breadcrumbNameFromPageTitle, localeHomePath } from '../../../lib/seo';
import { HTML_LANG_BY_ROUTE } from '../../../i18n/config';

export const prerender = true;

const locale = 'it';
const canonicalPath = '/it/spreadsheet';
const sheetUrl =
  import.meta.env.PUBLIC_MULEBUY_SPREADSHEET_URL?.trim() || `${ml}/spreadsheet/mulebuy`;

const howToHref = getRelativeLocaleUrl(locale, 'how-to-buy');
const newsHref = getRelativeLocaleUrl(locale, 'news');
const raw = getSpreadsheetPageCopy(locale);
const copy = hydrateSpreadsheetCopy(raw, `${ml}/spreadsheet/mulebuy`, howToHref, newsHref);
const homeHref = getRelativeLocaleUrl(locale, '');

const origin = Astro.site?.origin ?? 'https://mulebuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = canonicalHref(Astro.site, canonicalPath);

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: copy.title,
  url: pageUrl,
  description: copy.description,
  inLanguage: HTML_LANG_BY_ROUTE[locale],
  isPartOf: { '@id': websiteId },
  keywords: copy.keywords,
};

const breadcrumbLd = breadcrumbListLd(Astro.site, [
  { name: 'Home', path: localeHomePath(locale) },
  { name: breadcrumbNameFromPageTitle(copy.title), path: canonicalPath },
]);

---

<Layout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
  i18nRouteSegment="spreadsheet"
  jsonLd={[webPageLd, breadcrumbLd]}
>
  <SpreadsheetPageBody
    locale={locale}
    copy={copy}
    homeHref={homeHref}
    howToHref={howToHref}
    newsHref={newsHref}
    sheetUrl={sheetUrl}
  />
</Layout>
