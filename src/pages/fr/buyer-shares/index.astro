---
import Layout from '../../../layouts/Layout.astro';
import BuyerSharesPageBody from '../../../components/pages/BuyerSharesPageBody.astro';
import { canonicalHref, ml, siteStructuredDataIds } from '../../../consts';
import redditMulebuyShareSummaries from '../../../data/redditMulebuyShareSummaries.json';
import redditShippingShareSummaries from '../../../data/redditShippingShareSummaries.json';
import { getBuyerSharesCopy, hydrateBuyerSharesCopy } from '../../../i18n/copy/buyerShares';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { breadcrumbListLd, breadcrumbNameFromPageTitle, localeHomePath } from '../../../lib/seo';
import { HTML_LANG_BY_ROUTE } from '../../../i18n/config';
import type { RedditSharePick } from '../../../components/RedditBuyerSharesBlock.astro';

export const prerender = true;

const locale = 'fr';
const canonicalPath = '/fr/buyer-shares';
const buyerPicks = redditMulebuyShareSummaries as RedditSharePick[];
const shippingPicks = redditShippingShareSummaries as RedditSharePick[];

const raw = getBuyerSharesCopy(locale);
const copy = hydrateBuyerSharesCopy(raw, {
  newsUrl: getRelativeLocaleUrl(locale, 'news'),
  howToUrl: getRelativeLocaleUrl(locale, 'how-to-buy'),
});
const homeHref = getRelativeLocaleUrl(locale, '');

const origin = Astro.site?.origin ?? 'https://mulebuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = canonicalHref(Astro.site, canonicalPath);

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${pageUrl}#webpage`,
  name: copy.title,
  url: pageUrl,
  description: copy.description,
  inLanguage: HTML_LANG_BY_ROUTE[locale],
  isPartOf: { '@id': websiteId },
};

const breadcrumbLd = breadcrumbListLd(Astro.site, [
  { name: 'Home', path: localeHomePath(locale) },
  { name: breadcrumbNameFromPageTitle(copy.title), path: canonicalPath },
]);

---

<Layout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
  i18nRouteSegment="buyer-shares"
  jsonLd={[webPageLd]}
>
  <BuyerSharesPageBody
    locale={locale}
    copy={copy}
    homeHref={homeHref}
    buyerPicks={buyerPicks}
    shippingPicks={shippingPicks}
    galleryI18nJson={JSON.stringify(copy.gallery)}
  />
</Layout>
