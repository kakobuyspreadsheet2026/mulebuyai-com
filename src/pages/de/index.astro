---
import Layout from '../../layouts/Layout.astro';
import LocaleHomeStub from '../../components/LocaleHomeStub.astro';
import { deHome } from '../../i18n/stubs/de';
import { canonicalHref, ml, siteStructuredDataIds } from '../../consts';

export const prerender = true;

const locale = 'de';
const canonicalPath = '/de/';

const origin = Astro.site?.origin ?? 'https://mulebuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = canonicalHref(Astro.site, canonicalPath);

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: deHome.webPageName,
  url: pageUrl,
  description: deHome.description,
  inLanguage: 'de',
  isPartOf: { '@id': websiteId },
  keywords: deHome.webPageKeywords,
};
---

<Layout
  locale={locale}
  title={deHome.title}
  description={deHome.description}
  canonicalPath={canonicalPath}
  i18nRouteSegment=""
  jsonLd={webPageLd}
  showDiscordTopBanner={false}
>
  <LocaleHomeStub content={deHome} />
</Layout>
