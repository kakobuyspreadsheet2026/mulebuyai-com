---
import Layout from '../../../layouts/Layout.astro';
import HowToBuyPageBody from '../../../components/pages/HowToBuyPageBody.astro';
import { canonicalHref, ml, siteStructuredDataIds } from '../../../consts';
import { getHowToBuyCopy, hydrateHowToBuyCopy } from '../../../i18n/copy/howToBuy';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { breadcrumbListLd, breadcrumbNameFromPageTitle, localeHomePath } from '../../../lib/seo';
import { HTML_LANG_BY_ROUTE } from '../../../i18n/config';

export const prerender = true;

const locale = 'es';
const canonicalPath = '/es/how-to-buy';
const raw = getHowToBuyCopy(locale);
const copy = hydrateHowToBuyCopy(raw, `${ml}/spreadsheet/mulebuy`);
const homeHref = getRelativeLocaleUrl(locale, '');

const origin = Astro.site?.origin ?? 'https://mulebuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = canonicalHref(Astro.site, canonicalPath);

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: copy.title,
  url: pageUrl,
  description: copy.description,
  inLanguage: HTML_LANG_BY_ROUTE[locale],
  isPartOf: { '@id': websiteId },
  keywords: copy.keywords,
};

const breadcrumbLd = breadcrumbListLd(Astro.site, [
  { name: 'Home', path: localeHomePath(locale) },
  { name: breadcrumbNameFromPageTitle(copy.title), path: canonicalPath },
]);

---

<Layout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
  i18nRouteSegment="how-to-buy"
  jsonLd={[webPageLd, breadcrumbLd]}
>
  <HowToBuyPageBody locale={locale} copy={copy} homeHref={homeHref} />
</Layout>
