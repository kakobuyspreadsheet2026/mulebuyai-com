---
import SiteHeader from '../SiteHeader.astro';
import SiteFooter from '../SiteFooter.astro';
import type { NewsCopy } from '../../i18n/copy/newsPage';
import type { HomeCategoryBanner } from '../HomeCategoryBanners.astro';
import { withMulebuySpreadsheetAlt } from '../../lib/withMulebuySpreadsheetAlt';

interface Excerpt {
  title: string;
  sourceUrl: string;
  bodyHtml: string;
}

interface Props {
  locale: string;
  copy: NewsCopy;
  homeHref: string;
  banners: HomeCategoryBanner[];
  excerpts: Excerpt[];
}

const MULEBUY_HELP_HUB = 'https://mulebuy.com/';

const { locale, copy, homeHref, banners, excerpts } = Astro.props;

function isOutboundUrl(href: string) {
  return /^https?:\/\//i.test(href.trim());
}

function hasNavHref(href: string | undefined) {
  return typeof href === 'string' && href.trim().length > 0 && href.trim() !== '#';
}

const rowLen = Math.max(banners.length, copy.activityItems.length);
const bannerDecodeRows = Array.from({ length: rowLen }, (_, i) => ({
  banner: banners[i],
  item: copy.activityItems[i],
}));
---


<SiteHeader locale={locale} />

<main>
  <section class="band-alt">
    <div class="wrap">
      <div class="page-mast">
        <p class="news-back-link">
          <a href={homeHref}>{copy.backHomeLabel}</a>
        </p>
        <h1 class="simple-page-title" id="news-heading">{copy.h1}</h1>
        <p class="section-intro news-intro" set:html={copy.topIntroHtml} />

        <section class="news-banner-decode" aria-labelledby="news-banner-decode-heading">
          <h2 class="h2-sub" id="news-banner-decode-heading">{copy.featuredBannerHeading}</h2>
          <p class="section-intro news-banners-intro" set:html={copy.featuredBannerIntroHtml} />
          <p class="section-intro activity-explainer-intro news-banner-decode-lede" set:html={copy.activityIntroHtml} />

          <div class="news-banner-decode-list">
            {
              bannerDecodeRows.map((row, ri) => {
                const item = row.item;
                const banner = row.banner;
                if (!item && !banner) return null;
                const rawAlt =
                  banner?.alt?.trim() ||
                  (item
                    ? `Mulebuy Spreadsheet · ${item.title} — Mulebuy promo banner`
                    : 'Mulebuy Spreadsheet · Mulebuy promo banner');
                const alt = withMulebuySpreadsheetAlt(rawAlt);
                const linked = banner && hasNavHref(banner.href);
                const img =
                  banner != null ? (
                    <img
                      class="news-banner-decode-img"
                      src={banner.src}
                      alt={alt}
                      loading={ri === 0 ? 'eager' : 'lazy'}
                      fetchpriority={ri === 0 ? 'high' : undefined}
                      decoding="async"
                      referrerpolicy="no-referrer"
                    />
                  ) : null;

                return (
                  <article
                    class="news-banner-decode-card"
                    aria-labelledby={item ? `news-banner-decode-title-${ri}` : undefined}
                  >
                    <div class="news-banner-decode-visual">
                      {banner &&
                        (linked ? (
                          <a
                            class="news-banner-decode-link"
                            href={banner.href!.trim()}
                            target={isOutboundUrl(banner.href!) ? '_blank' : undefined}
                            rel={isOutboundUrl(banner.href!) ? 'noopener noreferrer' : undefined}
                            aria-label={
                              isOutboundUrl(banner.href!)
                                ? `${item?.title ?? alt} · opens in new tab`
                                : `${item?.title ?? alt} · on this site`
                            }
                          >
                            {img}
                          </a>
                        ) : (
                          <div class="news-banner-decode-img-shell">{img}</div>
                        ))}
                      {!banner && (
                        <div class="news-banner-decode-img-shell news-banner-decode-img-shell--missing">
                          <span class="news-banner-decode-missing">—</span>
                        </div>
                      )}
                    </div>

                    {item && (
                      <div class="news-banner-decode-body">
                        <h3 class="news-banner-decode-title" id={`news-banner-decode-title-${ri}`}>
                          {item.title}
                        </h3>
                        <span
                          class:list={[
                            'activity-explainer-pill',
                            item.pillVariant === 'internal'
                              ? 'activity-explainer-pill--internal'
                              : 'activity-explainer-pill--external',
                          ]}
                        >
                          {item.pillText}
                        </span>
                        <div class="news-banner-decode-copy" set:html={item.bodyHtml} />
                        <div class="news-banner-decode-copy" set:html={item.moreHtml} />
                      </div>
                    )}
                  </article>
                );
              })
            }
          </div>
        </section>

        <article class="official-sample" aria-labelledby="official-sample-heading">
          <div class="official-sample-head">
            <span class="official-sample-badge" id="official-sample-heading">{copy.official.badge}</span>
            <a
              class="official-sample-link"
              href={MULEBUY_HELP_HUB}
              target="_blank"
              rel="noopener noreferrer"
            >
              {copy.official.faqHubLabel}
            </a>
          </div>
          <p class="official-sample-meta" set:html={copy.official.metaHtml} />

          <div class="official-faq-stack" lang="zh-Hans">
            {
              excerpts.map((excerpt) => (
                <details class="official-faq-item">
                  <summary class="official-faq-summary">{excerpt.title}</summary>
                  <div class="official-faq-body">
                    <p class="official-faq-source">
                      <a href={excerpt.sourceUrl} target="_blank" rel="noopener noreferrer">
                        {copy.official.sourcePageLabel}
                      </a>
                    </p>
                    <div class="official-faq-html" set:html={excerpt.bodyHtml} />
                  </div>
                </details>
              ))
            }
          </div>
        </article>

        <h2 class="h2-sub">{copy.stepsHeading}</h2>
        <ol class="how-steps">
          {copy.stepListItemsHtml.map((html) => <li set:html={html} />)}
        </ol>

        <h2 class="h2-sub">{copy.tipsHeading}</h2>
        <ul class="how-tips">
          {copy.tipListItemsHtml.map((html) => <li set:html={html} />)}
        </ul>

        <p class="section-intro news-disclaimer" set:html={copy.disclaimerHtml} />
      </div>
    </div>
  </section>
</main>

<SiteFooter />

<style>
  .news-back-link {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
  }
  .news-intro {
    margin-top: 0;
  }
  .news-disclaimer {
    margin-bottom: 0;
  }
  .h2-sub {
    margin: 2rem 0 0.75rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  #news-banner-decode-heading.h2-sub {
    margin-top: 1.25rem;
  }

  .news-banners-intro {
    margin-top: 0 !important;
    margin-bottom: 0.65rem;
    max-width: 72rem;
  }

  .news-banner-decode-lede {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    max-width: 72rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .news-banner-decode-list {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    margin-top: 1.35rem;
    max-width: 52rem;
    min-width: 0;
  }

  .news-banner-decode-card {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 0.65rem;
    overflow: hidden;
    background: var(--surface);
    min-width: 0;
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
  }

  .news-banner-decode-visual {
    margin: 0;
    padding: 0;
    background: linear-gradient(180deg, var(--hero-surface-2, #f9f9fc) 0%, var(--surface) 100%);
    border-bottom: 1px solid var(--border);
  }

  .news-banner-decode-link {
    display: block;
    line-height: 0;
    outline-offset: 2px;
  }

  .news-banner-decode-link:hover .news-banner-decode-img {
    opacity: 0.96;
  }

  .news-banner-decode-link:focus-visible {
    outline: 2px solid var(--accent);
  }

  .news-banner-decode-img-shell {
    line-height: 0;
  }

  .news-banner-decode-img-shell--missing {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 6rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .news-banner-decode-missing {
    opacity: 0.45;
  }

  .news-banner-decode-img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: top;
  }

  .news-banner-decode-body {
    padding: 1rem 1.15rem 1.2rem;
    min-width: 0;
  }

  .news-banner-decode-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .activity-explainer-pill {
    display: inline-block;
    margin: 0 0 0.65rem;
    padding: 0.15rem 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    vertical-align: middle;
    border-radius: 999px;
  }
  .activity-explainer-pill--internal {
    color: var(--accent-dark);
    background: var(--accent-badge-bg, rgba(13, 148, 136, 0.14));
  }
  .activity-explainer-pill--external {
    color: #78350f;
    background: #ffedd5;
  }

  .news-banner-decode-copy :where(p) {
    margin: 0 0 0.45rem;
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: none;
    color: var(--muted);
  }

  .news-banner-decode-copy :where(p:last-child) {
    margin-bottom: 0;
  }

  .news-banner-decode-copy .activity-explainer-more {
    margin-top: 0.4rem !important;
    font-size: 0.84rem !important;
  }

  .news-banner-decode-copy .activity-explainer-more a {
    font-weight: 600;
  }

  .how-steps {
    margin: 0 0 1.5rem;
    padding-left: 1.35rem;
    max-width: 52rem;
    color: var(--muted);
    line-height: 1.65;
  }
  .how-steps li {
    margin-bottom: 0.85rem;
  }
  .how-steps strong {
    color: var(--text);
  }
  .how-tips {
    margin: 0 0 1rem;
    padding-left: 1.35rem;
    max-width: 52rem;
    color: var(--muted);
    line-height: 1.65;
  }
  .how-tips li {
    margin-bottom: 0.55rem;
  }

  .official-sample {
    margin: 2rem 0;
    padding: 1.35rem 1.25rem 1.5rem;
    max-width: 52rem;
    min-width: 0;
    background: linear-gradient(180deg, var(--hero-surface-2, #f9f9fc) 0%, var(--surface) 100%);
    border: 1px solid var(--border);
    border-radius: 0.65rem;
    border-left: 4px solid var(--accent);
    text-align: left;
  }
  .official-sample-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
    margin-bottom: 0.65rem;
  }
  .official-sample-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-dark);
    background: var(--accent-badge-bg);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
  }
  .official-sample-link {
    font-size: 0.8125rem;
    font-weight: 600;
  }
  .official-sample-meta {
    margin: 0 0 1rem;
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .official-faq-stack {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }
  .official-faq-item {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: #fff;
    min-width: 0;
    overflow-x: auto;
  }
  .official-faq-item[open] {
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06);
  }
  .official-faq-summary {
    cursor: pointer;
    list-style: none;
    padding: 0.85rem 2.25rem 0.85rem 1rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.45;
    position: relative;
    user-select: none;
  }
  .official-faq-summary::-webkit-details-marker {
    display: none;
  }
  .official-faq-summary::after {
    content: '';
    position: absolute;
    right: 1rem;
    top: 50%;
    width: 0.45rem;
    height: 0.45rem;
    border-right: 2px solid var(--muted);
    border-bottom: 2px solid var(--muted);
    transform: translateY(-65%) rotate(45deg);
    transition: transform 0.18s ease;
    opacity: 0.75;
  }
  .official-faq-item[open] .official-faq-summary::after {
    transform: translateY(-25%) rotate(-135deg);
  }
  .official-faq-summary:hover {
    background: rgba(13, 148, 136, 0.06);
  }
  .official-faq-body {
    padding: 0 1rem 1rem;
    border-top: 1px solid var(--border);
    background: #fafafa;
    min-width: 0;
  }
  .official-faq-source {
    margin: 0.75rem 0 0.35rem;
    font-size: 0.8125rem;
  }
  .official-faq-source a {
    font-weight: 600;
  }
  .official-faq-html {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--muted);
    min-width: 0;
  }
  .official-faq-html :where(p, ul, ol) {
    margin: 0 0 0.55rem;
  }
  .official-faq-html :where(ul, ol) {
    padding-left: 1.35rem;
  }
  .official-faq-html :where(li) {
    margin-bottom: 0.35rem;
  }
  .official-faq-html :where(strong, b) {
    color: var(--text);
  }
  .official-faq-html .help-table-class {
    overflow-x: auto;
    margin: 0.5rem 0 0.75rem;
    -webkit-overflow-scrolling: touch;
  }
  .official-faq-html :where(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .official-faq-html :where(th, td) {
    border: 1px solid var(--border);
    padding: 0.4rem 0.5rem;
    text-align: left;
    vertical-align: top;
  }
  .official-faq-html .ace-line {
    margin: 0 0 0.45rem;
  }
  .official-faq-html img {
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
  }
</style>
