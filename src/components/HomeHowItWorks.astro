                        <span class="mai-how__tl-dot" />
                        <span class="mai-how__tl-text">Hub scanning · route to WH</span>
                      </div>
                      <div class="mai-how__tl-row">
                        <span class="mai-how__tl-dot" />
                        <span class="mai-how__tl-text">Arrival photo pending</span>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {i === 3 && (
                <div class="mai-how__viz mai-how__viz--qc" aria-hidden="true">
                  <div class="mai-how__viz-row mai-how__viz-row--stretch">
                    <div class="mai-how__mock mai-how__mock--photo">
                      <div class="mai-how__mock-h">Warehouse photo</div>
                      <div class="mai-how__qc-photo">
                        <span class="mai-how__qc-badge">QC</span>
                      </div>
                      <div class="mai-how__qc-thumbs">
                        <span class="mai-how__qc-thumb is-active" />
                        <span class="mai-how__qc-thumb" />
                        <span class="mai-how__qc-thumb" />
                      </div>
                    </div>
                    <div class="mai-how__mock mai-how__mock--grow">
                      <div class="mai-how__mock-h">Inspection checklist</div>
                      <ul class="mai-how__qc-list">
                        <li class="mai-how__qc-li mai-how__qc-li--ok">
                          <span class="mai-how__qc-ico">✓</span> Outer packaging intact
                        </li>
                        <li class="mai-how__qc-li mai-how__qc-li--ok">
                          <span class="mai-how__qc-ico">✓</span> Label matches order ID
                        </li>
                        <li class="mai-how__qc-li mai-how__qc-li--wait">
                          <span class="mai-how__qc-ico">⋯</span> Awaiting your confirmation
                        </li>
                      </ul>
                      <div class="mai-how__qc-actions">
                        <span class="mai-how__qc-btn mai-how__qc-btn--ghost">Request retake</span>
                        <span class="mai-how__qc-btn">Approve storage</span>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {i === 4 && (
                <div class="mai-how__viz mai-how__viz--ship" aria-hidden="true">
                  <div class="mai-how__viz-row mai-how__viz-row--stretch">
                    <div class="mai-how__mock mai-how__mock--grow">
                      <div class="mai-how__mock-h">International parcel</div>
                      <div class="mai-how__ship-box">
                        <div class="mai-how__ship-tape" />
                        <span class="mai-how__ship-tag">CN → YOU</span>
                      </div>
                      <div class="mai-how__ship-meta">
                        <span class="mai-how__fake-line mai-how__fake-line--short" />
                        <span class="mai-how__fake-line mai-how__fake-line--w40" />
