---
/**
 * “How it works” — left step rail + right panel (Mulebuy-style).
 * Copy mirrors official checkout journey; mulebuyai.com stays the editorial hub.
 */
const steps = [
  {
    title: 'Search and Match',
    body:
      'Browse indexed Mulebuy Spreadsheet catalogue lanes or paste a trusted Taobao / Weidian / 1688 URL, then match that listing inside Mulebuy before you fund.',
  },
  {
    title: 'Pay for Goods',
    body:
      'Complete payment for your items inside Mulebuy so orders can be purchased on your behalf.',
  },
  {
    title: 'Order Reception and Transfer',
    body:
      'Once paid, orders move through reception and domestic transfer toward the warehouse workflow.',
  },
  {
    title: 'QC and Warehousing',
    body:
      'Quality checks and storage updates appear in your warehouse — review photos before shipping.',
  },
  {
    title: 'Submit International Shipping',
    body:
      'Choose lines, declare packages, and submit international shipping when you are ready.',
  },
  {
    title: 'Efficient Management',
    body:
      'Track parcels, messages, and account tools in one place for ongoing shipping management.',
  },
] as const;
---

<section class="mai-how band-alt" id="how-it-works" aria-labelledby="mai-how-heading">
  <div class="wrap mai-how__wrap">
    <h2 id="mai-how-heading" class="mai-how__heading">How it works</h2>
    <p class="mai-how__sub">
      After <strong>Mulebuy Spreadsheet</strong>-style discovery (indexed lanes + editorial notes on this site), the steps below follow{' '}
      <a href="https://mulebuy.com/" target="_blank" rel="noopener noreferrer">Mulebuy</a>
      checkout—quotes, domestic legs, warehouse QC, and labels stay on mulebuy.com only.
    </p>

    <div class="mai-how__grid" data-mai-how>
      <div class="mai-how__nav" role="tablist" aria-label="Mulebuy workflow steps">
        {
          steps.map((step, i) => (
            <button
              type="button"
              class:list={['mai-how__tab', i === 0 && 'is-active']}
              role="tab"
              id={`mai-how-tab-${i}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`mai-how-panel-${i}`}
              tabindex={i === 0 ? 0 : -1}
              data-how-tab={i}
            >
              <span class="mai-how__tab-step">{`Step ${String(i + 1).padStart(2, '0')}`}</span>
              <span class="mai-how__tab-title">{step.title}</span>
