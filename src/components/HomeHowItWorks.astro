              tabindex={0}
              hidden={i !== 0}
              data-how-panel={i}
            >
              <h3 class="mai-how__panel-title">{step.title}</h3>
              <p class="mai-how__panel-body">{step.body}</p>

              {i === 0 && (
                <div class="mai-how__viz" aria-hidden="true">
                  <div class="mai-how__viz-row">
                    <div class="mai-how__mock mai-how__mock--platform">
                      <div class="mai-how__mock-h">Platform Search</div>
                      <div class="mai-how__fake-search">
                        <span class="mai-how__fake-search-ico" />
                        <span class="mai-how__fake-search-input" />
                      </div>
                      <div class="mai-how__fake-rows">
                        <div class="mai-how__fake-row" />
                        <div class="mai-how__fake-row mai-how__fake-row--pick">
                          <span class="mai-how__fake-thumb" />
                          <span class="mai-how__fake-lines">
                            <span class="mai-how__fake-line" />
                            <span class="mai-how__fake-line mai-how__fake-line--short" />
                          </span>
                          <span class="mai-how__fake-plus">+</span>
                        </div>
