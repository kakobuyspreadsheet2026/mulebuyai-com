                          />
                        </svg>
                        Encrypted checkout on Mulebuy
                      </div>
                      <div class="mai-how__pay-cta">Confirm payment</div>
                    </div>
                  </div>
                </div>
              )}

              {i === 2 && (
                <div class="mai-how__viz mai-how__viz--flow" aria-hidden="true">
                  <div class="mai-how__flow-track">
                    <div class="mai-how__flow-node">
                      <span class="mai-how__flow-dot" />
                      <span class="mai-how__flow-label">Paid order</span>
                    </div>
                    <div class="mai-how__flow-arrow" />
                    <div class="mai-how__flow-node mai-how__flow-node--hot">
                      <span class="mai-how__flow-dot" />
                      <span class="mai-how__flow-label">Domestic transfer</span>
                    </div>
                    <div class="mai-how__flow-arrow" />
                    <div class="mai-how__flow-node">
                      <span class="mai-how__flow-dot" />
                      <span class="mai-how__flow-label">Warehouse inbound</span>
                    </div>
                  </div>
                  <div class="mai-how__mock mai-how__mock--below">
