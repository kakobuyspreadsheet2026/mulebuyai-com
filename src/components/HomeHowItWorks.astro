                    </div>
                    <div class="mai-how__mock mai-how__mock--grow">
                      <div class="mai-how__mock-h">Shipping line</div>
                      <div class="mai-how__ship-select">
                        <span class="mai-how__ship-select-val">Economy · tracked</span>
                        <span class="mai-how__ship-chev">▾</span>
                      </div>
                      <div class="mai-how__ship-declare">
                        <span class="mai-how__paste-label">Declared value</span>
                        <div class="mai-how__ship-input">$42.00 USD</div>
                      </div>
                      <div class="mai-how__pay-cta mai-how__pay-cta--inline">Submit shipment</div>
                    </div>
                  </div>
                </div>
              )}

              {i === 5 && (
                <div class="mai-how__viz mai-how__viz--dash" aria-hidden="true">
                  <div class="mai-how__dash-stats">
                    <div class="mai-how__dash-stat">
                      <span class="mai-how__dash-stat-n">12</span>
                      <span class="mai-how__dash-stat-l">Active</span>
                    </div>
                    <div class="mai-how__dash-stat">
                      <span class="mai-how__dash-stat-n">3</span>
                      <span class="mai-how__dash-stat-l">In transit</span>
                    </div>
                    <div class="mai-how__dash-stat mai-how__dash-stat--accent">
                      <span class="mai-how__dash-stat-n">2</span>
                      <span class="mai-how__dash-stat-l">Needs action</span>
                    </div>
                    <div class="mai-how__dash-stat">
                      <span class="mai-how__dash-stat-n">48</span>
                      <span class="mai-how__dash-stat-l">Delivered</span>
                    </div>
                  </div>
                  <div class="mai-how__mock mai-how__mock--below">
                    <div class="mai-how__mock-h">Parcel inbox</div>
                    <div class="mai-how__dash-rows">
                      <div class="mai-how__dash-row">
                        <span class="mai-how__dash-id">MU‑92841</span>
                        <span class="mai-how__dash-pill">Delivered</span>
                      </div>
                      <div class="mai-how__dash-row">
                        <span class="mai-how__dash-id">MU‑92876</span>
                        <span class="mai-how__dash-pill mai-how__dash-pill--hot">Customs doc</span>
                      </div>
                      <div class="mai-how__dash-row">
                        <span class="mai-how__dash-id">MU‑92902</span>
                        <span class="mai-how__dash-pill mai-how__dash-pill--prog">In transit</span>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function initMaiHow(root) {
    if (!(root instanceof HTMLElement)) return;
    if (root.dataset.maiHowBound === '1') return;
    root.dataset.maiHowBound = '1';

    const tabs = [...root.querySelectorAll('[data-how-tab]')];
    const panels = [...root.querySelectorAll('[data-how-panel]')];
    if (tabs.length === 0 || panels.length === 0) return;

    const show = (idx) => {
      const n = ((idx % tabs.length) + tabs.length) % tabs.length;
      tabs.forEach((t, j) => {
        const on = j === n;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.tabIndex = on ? 0 : -1;
      });
      panels.forEach((p, j) => {
        const on = j === n;
        p.classList.toggle('is-active', on);
        p.hidden = !on;
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => show(i));
      tab.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
          e.preventDefault();
          show(i + 1);
          tabs[(i + 1) % tabs.length]?.focus();
        }
        if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
          e.preventDefault();
          show(i - 1);
          tabs[(i - 1 + tabs.length) % tabs.length]?.focus();
        }
        if (e.key === 'Home') {
          e.preventDefault();
          show(0);
          tabs[0]?.focus();
        }
        if (e.key === 'End') {
          e.preventDefault();
          show(tabs.length - 1);
          tabs[tabs.length - 1]?.focus();
        }
      });
    });
  }

  function boot() {
    document.querySelectorAll('[data-mai-how]').forEach(initMaiHow);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .mai-how {
    --mai-how-orange: #ff9a1a;
    --mai-how-navy: #1a1f52;
    --mai-how-muted: #64748b;
    --mai-how-card: #f4f4f6;
    padding: clamp(2rem, 5vw, 3rem) 0;
  }

  .mai-how__wrap {
    text-align: left;
    max-width: min(72rem, 100%);
    margin-inline: auto;
  }

  .mai-how__heading {
    text-align: center;
    margin: 0 0 0.5rem;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .mai-how__sub {
    text-align: center;
    margin: 0 auto 2rem;
    max-width: 42rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--muted);
  }

  .mai-how__sub a {
    font-weight: 700;
    color: #6d28d9;
  }

  .mai-how__grid {
    display: grid;
    grid-template-columns: minmax(12.5rem, 15.5rem) minmax(0, 1fr);
    gap: clamp(1rem, 2.5vw, 1.75rem);
    align-items: start;
  }

  .mai-how__nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mai-how__tab {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    width: 100%;
    padding: 0.75rem 0.85rem;
    border-radius: 0.65rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: #ececf1;
    color: #334155;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .mai-how__tab:hover {
    border-color: rgba(245, 158, 11, 0.45);
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06);
  }

  .mai-how__tab.is-active {
    background: var(--mai-how-navy);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 10px 28px rgba(26, 31, 82, 0.25);
  }

  .mai-how__tab-step {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.92;
  }

  .mai-how__tab:not(.is-active) .mai-how__tab-step {
    color: #475569;
  }

  .mai-how__tab-title {
    font-size: 0.875rem;
    font-weight: 650;
    line-height: 1.35;
  }

  .mai-how__panels {
    min-width: 0;
    border-radius: 0.85rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: #fff;
    padding: clamp(1.15rem, 2.5vw, 1.65rem);
    box-shadow: 0 12px 36px rgba(15, 23, 42, 0.06);
  }

  .mai-how__panel-title {
    margin: 0 0 0.45rem;
    font-size: clamp(1.25rem, 2.4vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .mai-how__panel-body {
    margin: 0 0 1.25rem;
    max-width: 48rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--mai-how-muted);
  }

  .mai-how__viz {
    margin-top: 0.25rem;
  }

  .mai-how__viz-row {
    display: flex;
    align-items: stretch;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .mai-how__mock {
    flex: 1 1 13rem;
    min-width: min(100%, 13rem);
    border-radius: 0.65rem;
    background: var(--mai-how-card);
    border: 1px solid rgba(15, 23, 42, 0.06);
    padding: 0.65rem 0.75rem 0.85rem;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
  }

  .mai-how__mock--url {
    background: #fafafa;
    position: relative;
  }

  .mai-how__mock-h {
    font-size: 0.68rem;
    font-weight: 800;
    color: #475569;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .mai-how__fake-search {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: #fff;
    border-radius: 0.45rem;
    padding: 0.35rem 0.45rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    margin-bottom: 0.5rem;
  }

  .mai-how__fake-search-ico {
    width: 0.85rem;
    height: 0.85rem;
    border: 2px solid #94a3b8;
    border-radius: 999px;
    flex-shrink: 0;
    box-sizing: border-box;
    opacity: 0.85;
  }

  .mai-how__fake-search-input {
    flex: 1;
    height: 0.35rem;
    border-radius: 3px;
    background: #e2e8f0;
  }

  .mai-how__fake-rows {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .mai-how__fake-row {
    height: 2.35rem;
    border-radius: 0.45rem;
    background: #e8e8ec;
    border: 1px solid transparent;
  }

  .mai-how__fake-row--pick {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem;
    background: #fff;
    border-color: var(--mai-how-orange);
    box-shadow: 0 0 0 1px var(--mai-how-orange);
  }

  .mai-how__fake-thumb {
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 0.25rem;
    background: linear-gradient(145deg, #cbd5e1, #94a3b8);
    flex-shrink: 0;
  }

  .mai-how__fake-thumb--lg {
    width: 2.25rem;
    height: 2.25rem;
  }

  .mai-how__fake-lines {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .mai-how__fake-line {
    height: 0.32rem;
    border-radius: 2px;
    background: #cbd5e1;
  }

  .mai-how__fake-line--short {
    width: 55%;
  }

  .mai-how__fake-line--w40 {
    width: 40%;
  }

  .mai-how__fake-plus {
    width: 1.35rem;
